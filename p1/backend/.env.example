# ---- Claude (Anthropic) ----
# 调试阶段用 Claude API。留空则使用运行环境已配置的凭证 / OAuth profile。
ANTHROPIC_API_KEY=
# 默认模型;想更省更快可改为 claude-haiku-4-5 或 claude-sonnet-5
CLAUDE_MODEL=claude-opus-4-8

# ---- OpenAI 兼容接口(可选,任意兼容 /v1/chat/completions 的服务)----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- 本地开源模型 (Ollama) ----
# 先在本机部署:  ollama pull qwen2.5:7b   然后 ollama serve 默认监听 11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
